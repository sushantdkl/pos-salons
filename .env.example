# cPanel PostgreSQL database.
# Create the DB/user in cPanel PostgreSQL Databases and assign all privileges.
DATABASE_URL=postgresql://CPANEL_DB_USER:DB_PASSWORD@localhost:5432/CPANEL_DB_NAME

# Use PG_SSL=false for cPanel localhost/127.0.0.1 PostgreSQL unless your host explicitly requires SSL.
PG_SSL=false
PG_POOL_MAX=5

# Auth/site configuration.
NEXTAUTH_SECRET=replace-with-a-secure-random-secret
NEXTAUTH_URL=https://thehaircut.com.np
NEXT_PUBLIC_SITE_URL=https://thehaircut.com.np
NEXT_PUBLIC_LICENSE_ENABLED=false
NEXT_PUBLIC_SALON_WHATSAPP_NUMBER=9779858051694

# cPanel runtime uploads for Website CMS, payment QR, gallery, staff, service, package, banner, and SEO images.
# These files must live outside src/app/build folders and be publicly accessible from the domain.
UPLOAD_DIR=/home/CPANEL_USERNAME/public_html/uploads/website-assets
NEXT_PUBLIC_UPLOAD_BASE_URL=https://thehaircut.com.np/uploads/website-assets
