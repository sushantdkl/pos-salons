# Local dev: Supabase → Database → Connection string → URI (direct, port 5432)
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[project-ref].supabase.co:5432/postgres

# Vercel/production: use Transaction pooler (port 6543), NOT the direct :5432 URL
# Supabase → Database → Connection string → Transaction pooler → URI
# SUPABASE_DB_URL=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres

# Optional alias (same postgres URL)
DATABASE_URL=

NEXT_PUBLIC_LICENSE_ENABLED=false
NEXT_PUBLIC_SALON_WHATSAPP_NUMBER=9779858051694
NEXT_PUBLIC_SITE_URL=https://pos-salons.vercel.app
NEXTAUTH_SECRET=change-this-secret-before-production
NEXTAUTH_URL=https://pos-salons.vercel.app

# cPanel runtime uploads for Website CMS images.
# Uploaded files are runtime assets and should live outside src/app/components/public/assets.
UPLOAD_DIR=/home/YOUR_CPANEL_USERNAME/public_html/uploads/website-assets
NEXT_PUBLIC_UPLOAD_BASE_URL=https://yourdomain.com/uploads/website-assets

# Set PG_SSL=false only for local Postgres without SSL
# PG_POOL_MAX=5
