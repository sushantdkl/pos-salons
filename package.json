{
  "name": "salon-pos-system",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack -p 3002",
    "build": "next build",
    "start": "node server.js",
    "lint": "eslint",
    "package": "npm run build && pkg . --out-path dist"
  },
  "bin": "server.js",
  "pkg": {
    "assets": [
      ".next/**/*",
      "public/**/*",
      "src/**/*"
    ],
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "dist"
  },
  "dependencies": {
    "autoprefixer": "^10.4.22",
    "bcryptjs": "^3.0.3",
    "lucide-react": "^0.553.0",
    "next": "^16.2.7",
    "pg": "^8.12.0",
    "react": "19.2.1",
    "react-dom": "19.2.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9",
    "eslint-config-next": "16.0.3",
    "pkg": "^5.8.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0"
  }
}
